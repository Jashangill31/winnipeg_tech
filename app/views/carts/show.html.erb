<h1>Your Shopping Cart</h1>

<% if @cart_items.empty? %>
  <p>Your cart is empty.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Qty</th>
        <th>Price</th>
        <th>Total</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td><%= item[:product].name %></td>
          <td>
            <%= form_with url: cart_item_path(item[:product].id), method: :patch do %>
              <%= number_field_tag :quantity, item[:quantity], min: 1 %>
              <%= submit_tag "Update" %>
            <% end %>
          </td>
          <td>$<%= item[:product].price %></td>
          <td>$<%= (item[:product].price * item[:quantity]).round(2) %></td>
          <td>
            <%= button_to "Remove", cart_item_path(item[:product].id), method: :delete, data: { confirm: "Remove this item?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h3>Total: $<%= @cart_items.sum { |item| item[:product].price * item[:quantity] }.round(2) %></h3>
  <%= link_to "Proceed to Checkout", new_order_path, class: "btn btn-success", style: "margin-top: 20px; display: inline-block;" %>

<% end %>
