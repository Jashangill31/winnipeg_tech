<h1>Your Cart</h1>

<% if @cart_items.any? %>
  <ul>
    <% @products.each do |product| %>
      <li>
        <strong><%= product.name %></strong> —
        Quantity: <%= session[:cart][product.id.to_s] %>
        <%= button_to "Remove", cart_item_path(product_id: product.id), method: :delete %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>Your cart is empty.</p>
<% end %>
