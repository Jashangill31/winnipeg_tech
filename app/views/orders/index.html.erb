<h1>Your Order History</h1>

<% if @orders.empty? %>
  <p>You haven't placed any orders yet.</p>
<% else %>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr>
        <th style="border-bottom: 1px solid #ccc; padding: 8px;">Order #</th>
        <th style="border-bottom: 1px solid #ccc; padding: 8px;">Date</th>
        <th style="border-bottom: 1px solid #ccc; padding: 8px;">Status</th>
        <th style="border-bottom: 1px solid #ccc; padding: 8px;">Total</th>
        <th style="border-bottom: 1px solid #ccc; padding: 8px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td style="padding: 8px;"><%= order.id %></td>
          <td style="padding: 8px;"><%= order.created_at.strftime("%b %d, %Y") %></td>
          <td style="padding: 8px;"><%= order.status.capitalize %></td>
          <td style="padding: 8px;">$<%= sprintf("%.2f", order.total) %></td>
          <td style="padding: 8px;"><%= link_to "View", order_path(order) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<%= link_to "Continue Shopping", root_path, class: "btn btn-primary", style: "margin-top: 20px;" %>
